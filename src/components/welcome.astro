---
import { Image } from "astro:assets";
import background from "@/assets/background.svg";
import gitHubIcon from "@/assets/github.svg";
import logicaIcon from "@/assets/icon.webp";
import xIcon from "@/assets/x.png";
import { type Locales, useTranslations } from "@/utils/i18n";

interface Props {
  locale: Locales;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<div class="welcome-root">
  <img
    src={background.src}
    alt=""
    aria-hidden="true"
    class="welcome-background"
  />
  <main class="welcome-main">
    <section class="welcome-content">
      <Image
        src={logicaIcon}
        width="100"
        height="100"
        alt="logica Icon"
        class="welcome-icon"
      />
      <h1 class="welcome-title">🚧 {t("Under Construction")} 🚧</h1>
      <section class="welcome-links">
        <a class="welcome-link" href="https://github.com/logica0419">
          <img src={gitHubIcon.src} width="20" height="20" alt="GitHub" />
        </a>
        <a class="welcome-link" href="https://x.com/logica0419">
          <Image src={xIcon} width="20" height="20" alt="X" />
        </a>
      </section>
    </section>
  </main>
</div>

<style>
  .welcome-root {
    min-height: 100dvh;
  }

  .welcome-background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -10;
    filter: blur(100px);
  }

  .welcome-main {
    min-height: 100dvh;
    display: flex;
    justify-content: center;
  }

  .welcome-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .welcome-icon {
    margin-bottom: 0.25rem;
  }

  .welcome-title {
    margin-top: 0.25rem;
    font-size: 22px;
  }

  .welcome-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .welcome-link {
    display: flex;
    align-items: center;
    padding: 0.625rem;
    color: #ffffff;
    background: linear-gradient(90deg, #3245ff 0%, #bc52ee 100%);
    border-radius: 10px;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.12),
      inset 0 -3px 0 rgba(0, 0, 0, 0.24);
    text-decoration: none;
    transition:
      color 150ms ease,
      box-shadow 150ms ease;
  }

  .welcome-link:hover {
    color: rgb(230, 230, 230);
    box-shadow: none;
  }

  @media (min-width: 768px) {
    .welcome-links {
      flex-wrap: nowrap;
    }
  }
</style>
